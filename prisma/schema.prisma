generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ────────────────────────────────────────
// ユーザー（会員 + 管理者）
// ────────────────────────────────────────
model User {
  id            String    @id @default(cuid())
  loginId       String    @unique           // ログインID
  email         String    @unique
  passwordHash  String
  role          Role      @default(MEMBER)
  name          String
  nameKana      String?
  nameRomaji    String?                       // ローマ字氏名（カード表示用）
  phone         String?
  dateOfBirth   DateTime?
  postalCode    String?
  address       String?
  occupation    String?                       // 職業
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  lastLoginAt   DateTime?
  isActive      Boolean   @default(true)
  isIdIssued    Boolean   @default(false)   // ID発行済みか
  mustChangePassword Boolean @default(true)
  hasAgreedTerms     Boolean @default(false)  // 重要事項説明に同意済みか
  agreedTermsAt      DateTime?                // 同意日時
  hasAgreedPamphlet  Boolean @default(false)  // パンフレット免責事項に同意済みか
  agreedPamphletAt   DateTime?                // パンフレット同意日時

  // 申込情報（フォームから登録時に保存）
  applicationId    String?                    // 元の申込ID
  paymentMethod    String?                    // 支払方法
  paymentDate      DateTime?                  // 支払予定日
  salesRepName     String?                    // 担当営業者名

  // 健康状態（事前確認事項）
  currentIllness       Boolean  @default(false)
  currentIllnessDetail String?
  pastIllness          Boolean  @default(false)
  pastIllnessDetail    String?
  currentMedication    Boolean  @default(false)
  currentMedicationDetail String?
  chronicDisease       Boolean  @default(false)
  chronicDiseaseDetail String?
  infectiousDisease    Boolean  @default(false)
  infectiousDiseaseDetail String?
  pregnancy            Boolean  @default(false)
  allergy              Boolean  @default(false)
  allergyDetail        String?
  otherHealth          Boolean  @default(false)
  otherHealthDetail    String?

  referredByAgency String?                  // 紹介元エージェントコード
  referredByStaff  String?                  // 担当従業員コード (ST-0001形式)

  membership    Membership?
  notes         AdminNote[]
  documents     Document[]
  statusHistory StatusHistory[]
  agencyProfile AgencyProfile?
  staffProfile  Staff?
  favorites           Favorite[]
  consentLogs         ConsentLog[]
  accessLogs          AccessLog[]
  cultureFluidOrders  CultureFluidOrder[]
}

enum Role {
  MEMBER
  ADMIN
  SUPER_ADMIN
  AGENCY
  STAFF
}

// ────────────────────────────────────────
// 会員権（1ユーザー = 1会員権）
// ────────────────────────────────────────
model Membership {
  id              String          @id @default(cuid())
  userId          String          @unique
  user            User            @relation(fields: [userId], references: [id])
  memberNumber    String          @unique
  plan            MembershipPlan  @default(STANDARD)
  contractDate    DateTime
  paymentStatus   PaymentStatus   @default(PENDING)
  totalAmount     Int
  paidAmount      Int             @default(0)

  ipsStatus       IpsStatus       @default(REGISTERED)
  clinicDate      DateTime?
  clinicName      String?                       // 提携クリニック名
  clinicAddress   String?                       // クリニック住所
  clinicPhone     String?                       // クリニック電話番号
  ipsCompletedAt  DateTime?
  storageStartAt  DateTime?
  storageYears    Int             @default(10)

  serviceAppliedAt  DateTime?       // サービス申込日時
  consentSignedAt   DateTime?       // 同意書署名日時
  contractFormat    String?         // 契約書の形式（electronic=電子署名, paper=書面契約）
  contractSignedAt  DateTime?       // 契約書署名完了日時
  deathWish         String?         // 死亡時意思表示（donate=寄贈, dispose=廃棄）

  treatments      Treatment[]

  referrerId      String?
  referrerName    String?

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

enum MembershipPlan {
  STANDARD
}

enum PaymentStatus {
  PENDING
  PARTIAL
  COMPLETED
}

enum IpsStatus {
  REGISTERED           // ① メンバー登録済み（ID発行された状態）
  TERMS_AGREED         // ② 重要事項確認済み
  SERVICE_APPLIED      // ③ iPSサービス申込み済み（880万円支払い）
  SCHEDULE_ARRANGED    // ④ iPS作成日程調整
  BLOOD_COLLECTED      // ⑤ クリニック問診と採血
  IPS_CREATING         // ⑥ iPS作成中
  STORAGE_ACTIVE       // ⑦ iPS保管中
  STORAGE_EXPIRED      // 保管期間満了
  // 旧enum値（マイグレーション互換用、新規では使用しない）
  APPLICATION
  CONTRACT_SIGNED
  CLINIC_RESERVED
  IPS_COMPLETED
}

// ────────────────────────────────────────
// ステータス履歴（変更ログ）
// ────────────────────────────────────────
model StatusHistory {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  fromStatus  IpsStatus
  toStatus    IpsStatus
  note        String?
  changedBy   String
  changedAt   DateTime  @default(now())
}

// ────────────────────────────────────────
// 培養上清液 投与記録
// ────────────────────────────────────────
model Treatment {
  id            String          @id @default(cuid())
  membershipId  String
  membership    Membership      @relation(fields: [membershipId], references: [id])
  type          TreatmentType
  volume        Int             @default(10)
  amount        Int
  scheduledAt   DateTime?
  completedAt   DateTime?
  clinicName    String?
  note          String?
  createdAt     DateTime        @default(now())
}

enum TreatmentType {
  IV_DRIP
  LOCAL_INJECTION
}

// ────────────────────────────────────────
// 契約書類
// ────────────────────────────────────────
model Document {
  id          String         @id @default(cuid())
  userId      String
  user        User           @relation(fields: [userId], references: [id])
  type        DocumentType
  title       String
  fileUrl     String?
  signedAt    DateTime?
  status      DocumentStatus @default(PENDING)
  createdAt   DateTime       @default(now())
}

enum DocumentType {
  CONTRACT
  SERVICE_TERMS             // iPSサービス利用規約
  CONSENT_CELL_STORAGE
  CELL_STORAGE_CONSENT      // 細胞提供・保管同意書
  INFORMED_CONSENT
  PRIVACY_POLICY
  SIMPLE_AGREEMENT
}

enum DocumentStatus {
  PENDING
  SENT
  SIGNED
  ARCHIVED
}

// ────────────────────────────────────────
// 管理者メモ（顧客カルテ用）
// ────────────────────────────────────────
model AdminNote {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  content   String
  author    String
  createdAt DateTime @default(now())
}

// ────────────────────────────────────────
// サイト設定（規約・特商法等の編集可能テキスト）
// ────────────────────────────────────────
model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique                // 設定キー（terms, legal, privacy, important_notice）
  title     String                          // 表示タイトル
  content   String   @db.Text              // HTML/テキスト内容
  updatedBy String?                        // 最終更新者
  updatedAt DateTime @updatedAt
}

// ────────────────────────────────────────
// iPS ニュース記事（管理者が随時更新）
// ────────────────────────────────────────
model IpsArticle {
  id          String           @id @default(cuid())
  slug        String           @unique
  title       String
  summary     String
  content     String           @db.Text
  category    IpsArticleCategory
  imageUrl    String?
  sourceUrl   String?
  sourceName  String?
  publishedAt DateTime         @default(now())
  isPublished Boolean          @default(false)
  author      String
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

enum IpsArticleCategory {
  NEWS          // 最新ニュース
  RESEARCH      // 研究動向
  CLINICAL      // 臨床応用
  REGULATION    // 制度・規制
  MARKET        // 市場動向
}

// ────────────────────────────────────────
// 動画コンテンツ（YouTube埋め込み）
// ────────────────────────────────────────
model Video {
  id          String    @id @default(cuid())
  title       String
  description String?   @db.Text
  youtubeUrl  String                          // YouTube動画URL
  youtubeId   String                          // YouTube動画ID（埋め込み用）
  thumbnailUrl String?                        // サムネイル（YouTubeから自動取得）
  isPublished Boolean   @default(false)
  publishedAt DateTime  @default(now())
  author      String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ────────────────────────────────────────
// 外部ニュース（API自動取得）
// ────────────────────────────────────────
model ExternalNews {
  id          String    @id @default(cuid())
  title       String
  summary     String?   @db.Text
  sourceUrl   String    @unique               // 元記事URL（重複防止）
  sourceName  String                          // 出典名
  imageUrl    String?                         // OGP画像URL（自動取得）
  isPublished Boolean   @default(false)       // 管理者が公開承認したか
  publishedAt DateTime
  fetchedAt   DateTime  @default(now())
}

// ────────────────────────────────────────
// お気に入り（会員がコンテンツをブックマーク）
// ────────────────────────────────────────
model Favorite {
  id          String       @id @default(cuid())
  userId      String
  user        User         @relation(fields: [userId], references: [id])
  contentType FavoriteType                    // コンテンツの種類
  contentId   String                          // 対象コンテンツのID
  createdAt   DateTime     @default(now())

  @@unique([userId, contentType, contentId]) // 同じコンテンツの重複防止
}

enum FavoriteType {
  ARTICLE        // 自社投稿記事（IpsArticle）
  VIDEO          // 動画（Video）
  EXTERNAL_NEWS  // 外部ニュース（ExternalNews）
}

// ────────────────────────────────────────
// 同意ログ（免責事項・資料閲覧同意の詳細記録）
// ────────────────────────────────────────
model ConsentLog {
  id                  String   @id @default(cuid())
  userId              String
  user                User     @relation(fields: [userId], references: [id])
  memberEmail         String                         // 記録時点のメールアドレス
  membershipStatus    String?                        // 記録時点の会員ステータス

  // 対象資料
  documentId          String                         // 資料ID（例: "pamphlet-v1"）
  documentTitle       String                         // 資料名
  documentVersion     String                         // 資料バージョン
  documentUrl         String?                        // 資料URL

  // 同意文面
  consentTextVersion  String                         // 免責文面のバージョン
  consentTextSnapshot String   @db.Text              // 表示された免責文面の全文

  // アクション
  consentAction       String   @default("agreed")    // agreed / revoked
  popupDisplayedAt    DateTime?                      // ポップアップ表示時刻
  consentedAt         DateTime @default(now())       // 同意時刻
  viewStartedAt       DateTime?                      // 閲覧開始時刻

  // 技術情報
  ipAddress           String?
  userAgent           String?  @db.Text
  sessionId           String?

  createdAt           DateTime @default(now())
}

// ────────────────────────────────────────
// アクセスログ（ページ閲覧記録）
// ────────────────────────────────────────
model AccessLog {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  path        String                          // 閲覧ページのパス
  pageTitle   String?                         // ページタイトル
  ipAddress   String?
  userAgent   String?  @db.Text
  referer     String?                         // リファラー
  accessedAt  DateTime @default(now())

  @@index([userId, accessedAt])
  @@index([accessedAt])
}

// ────────────────────────────────────────
// 購入申込（BioVault申込書）
// ────────────────────────────────────────
model Application {
  id                String            @id @default(cuid())

  // 1. 申込者情報
  name              String                                // 氏名
  nameKana          String                                // フリガナ
  dateOfBirth       DateTime                              // 生年月日
  postalCode        String?                               // 郵便番号
  address           String                                // 住所
  phone             String                                // 電話番号
  email             String                                // メールアドレス
  occupation        String?                               // 職業

  // 2. 申込内容
  paymentMethod     String            @default("bank_transfer") // 支払方法
  paymentMethodOther String?                              // その他の場合
  paymentDate       DateTime?                             // 支払予定日
  referrerName      String?                               // 紹介者名／代理店名
  salesRepName      String?                               // 担当営業者名
  staffCode         String?                               // 担当従業員コード

  // 3. 事前確認事項（健康状態）
  currentIllness       Boolean  @default(false)           // 現在治療中の病気
  currentIllnessDetail String?
  pastIllness          Boolean  @default(false)           // 過去の病気・手術歴
  pastIllnessDetail    String?
  currentMedication    Boolean  @default(false)           // 現在使用中の薬
  currentMedicationDetail String?
  chronicDisease       Boolean  @default(false)           // 持病
  chronicDiseaseDetail String?
  infectiousDisease    Boolean  @default(false)           // 感染症
  infectiousDiseaseDetail String?
  pregnancy            Boolean  @default(false)           // 妊娠中/可能性
  allergy              Boolean  @default(false)           // アレルギー
  allergyDetail        String?
  otherHealth          Boolean  @default(false)           // その他健康上の事項
  otherHealthDetail    String?

  // 4. 確認事項チェック
  confirmNotMedical    Boolean  @default(false)           // 医療行為でないことの確認
  confirmScppRole      Boolean  @default(false)           // SCPPの役割確認
  confirmClinicRole    Boolean  @default(false)           // 提携医療機関の役割確認
  confirmLabRole       Boolean  @default(false)           // 提携先機関の役割確認
  confirmDocuments     Boolean  @default(false)           // 関連文書の確認

  // 5. 受領確認文書
  receivedContract     Boolean  @default(false)           // 会員契約書
  receivedTerms        Boolean  @default(false)           // 会員規約
  receivedImportant    Boolean  @default(false)           // 重要事項説明書
  receivedMedicalCheck Boolean  @default(false)           // 医師問診確認書
  receivedPrivacy      Boolean  @default(false)           // 個人情報同意書
  receivedCellStorage  Boolean  @default(false)           // 細胞保管同意書
  receivedIpsConsent   Boolean  @default(false)           // iPS細胞説明書

  // ステータス管理
  status            ApplicationStatus @default(PENDING)
  adminNote         String?                               // 管理者メモ
  convertedUserId   String?                               // 会員登録済みの場合のユーザーID

  applicationDate   DateTime  @default(now())             // 申込日
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

enum ApplicationStatus {
  PENDING           // 申込受付
  REVIEWING         // iPS作成適合確認中
  APPROVED          // 承認済
  REGISTERED        // 会員登録済
  REJECTED          // 却下
}

// ────────────────────────────────────────
// 代理店プロフィール（1:1 with User）
// ────────────────────────────────────────
model AgencyProfile {
  id                  String    @id @default(cuid())
  userId              String    @unique
  user                User      @relation(fields: [userId], references: [id])
  agencyCode          String    @unique             // AG-0001形式
  companyName         String?                       // 法人名
  representativeName  String?                       // 代表者名
  commissionRate      Float     @default(0)         // 基本成果報酬率(%)
  bankName            String?                       // 振込先銀行
  bankBranch          String?                       // 支店名
  bankAccountType     String?                       // 口座種別（普通/当座）
  bankAccountNumber   String?                       // 口座番号
  bankAccountName     String?                       // 口座名義
  hasAgreedContract   Boolean   @default(false)     // 代理店契約書同意
  hasAgreedPledge     Boolean   @default(false)     // 遵守誓約書同意
  hasAgreedNda        Boolean   @default(false)     // NDA同意
  agreedAt            DateTime?                     // 全同意完了日時
  isActive            Boolean   @default(true)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  commissions         AgencyCommission[]
}

// ────────────────────────────────────────
// 代理店報酬記録
// ────────────────────────────────────────
model AgencyCommission {
  id                String           @id @default(cuid())
  agencyProfileId   String
  agencyProfile     AgencyProfile    @relation(fields: [agencyProfileId], references: [id])
  memberUserId      String                          // 紹介した会員のID
  memberName        String                          // 会員名
  memberNumber      String                          // 会員番号
  saleAmount        Int                             // 売上金額
  commissionRate    Float                           // 適用報酬率(%)
  commissionAmount  Int                             // 報酬金額
  contributionType  String                          // 紹介のみ/説明補助/クロージング協力
  status            CommissionStatus @default(PENDING)
  paidAt            DateTime?
  note              String?
  createdAt         DateTime         @default(now())
}

enum CommissionStatus {
  PENDING           // 未確定
  CONFIRMED         // 確定
  PAID              // 支払済
  CANCELLED         // 取消
}

// ────────────────────────────────────────
// 代理店申込
// ────────────────────────────────────────
model AgencyApplication {
  id                  String            @id @default(cuid())
  companyName         String?                       // 法人名（個人の場合は空）
  representativeName  String                        // 代表者名/氏名
  nameKana            String                        // フリガナ
  email               String
  phone               String
  postalCode          String?
  address             String
  occupation          String?
  motivation          String?           @db.Text    // 申込動機
  experience          String?           @db.Text    // 営業経験
  status              ApplicationStatus @default(PENDING)
  convertedUserId     String?                       // ユーザー登録済みの場合
  adminNote           String?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
}

// ────────────────────────────────────────
// パンフレット印刷依頼
// ────────────────────────────────────────
model PrintRequest {
  id                 String       @id @default(cuid())
  agencyUserId       String
  agencyCode         String
  companyName        String
  representativeName String
  quantity           Int                               // 部数（100枚単位）
  postalCode         String?
  shippingAddress    String
  paymentMethod      String       @default("cod")     // cod=代引き, bank_transfer=銀行振込
  note               String?      @db.Text
  // 進捗ステータス
  status             PrintRequestStatus @default(REQUESTED)
  confirmedAt        DateTime?                         // 本部確認日時
  bankInfo           String?                           // 振込先情報（銀行振込の場合）
  paidAt             DateTime?                         // 入金確認日時
  orderedAt          DateTime?                         // 本部発注日時
  adminNote          String?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
}

enum PrintRequestStatus {
  REQUESTED         // 申請
  CONFIRMED         // 本部確認済
  AWAITING_PAYMENT  // 入金待ち（銀行振込の場合）
  PAID              // 入金確認済（銀行振込の場合）
  ORDERED           // 本部発注済
  CANCELLED         // キャンセル
}

// ────────────────────────────────────────
// コンテンツ更新通知
// ────────────────────────────────────────
model ContentUpdate {
  id          String   @id @default(cuid())
  title       String                          // 更新タイトル（例: 「注目ニュースを更新しました」）
  contentType String                          // article / video / news
  contentId   String?                         // 対象コンテンツのID（任意）
  linkUrl     String?                         // リンク先URL
  publishedAt DateTime @default(now())        // 公開日時
  createdAt   DateTime @default(now())
}

// コンテンツ更新の既読管理（ユーザーごと）
model ContentUpdateRead {
  id              String   @id @default(cuid())
  userId          String
  contentUpdateId String
  readAt          DateTime @default(now())

  @@unique([userId, contentUpdateId])          // 同じ通知を二重既読にしない
  @@index([userId])
}

// プッシュ通知用のサブスクリプション管理
model PushSubscription {
  id           String   @id @default(cuid())
  userId       String
  endpoint     String   @unique               // Web Pushエンドポイント
  p256dh       String                          // 公開鍵
  auth         String                          // 認証トークン
  createdAt    DateTime @default(now())

  @@index([userId])
}

// ────────────────────────────────────────
// 従業員マスタ（営業担当者の管理用）
// ────────────────────────────────────────
model Staff {
  id        String   @id @default(cuid())
  staffCode String   @unique              // ST-0001形式
  name      String                        // 氏名
  nameKana  String?                       // フリガナ
  email     String?                       // メールアドレス
  note      String?  @db.Text             // 備考
  isActive  Boolean  @default(true)       // 有効/無効
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ログイン用Userとの紐付け（ID発行時に設定）
  userId    String?  @unique
  user      User?    @relation(fields: [userId], references: [id])
}

// ────────────────────────────────────────
// 振込先一覧（入金先情報マスタ）
// ────────────────────────────────────────
model BankAccount {
  id            String   @id @default(cuid())
  bankName      String                        // 銀行名
  branchName    String                        // 支店名
  accountType   String   @default("普通")     // 口座種別（普通/当座）
  accountNumber String                        // 口座番号
  accountName   String                        // 口座名義
  isDefault     Boolean  @default(false)      // デフォルト振込先
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ────────────────────────────────────────
// クリニック一覧（提携クリニック マスタ）
// ────────────────────────────────────────
model Clinic {
  id        String   @id @default(cuid())
  name      String                        // クリニック名
  address   String?                       // 住所
  phone     String?                       // 電話番号
  note      String?  @db.Text             // 備考
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ────────────────────────────────────────
// 用語集（iPSとは？ページの用語管理）
// ────────────────────────────────────────
model GlossaryTerm {
  id          String   @id @default(cuid())
  term        String                        // 用語名
  reading     String?                       // 読み
  english     String?                       // 英語名
  description String   @db.Text             // 説明
  category    String   @default("basic")    // basic/medical/biovault
  sortOrder   Int      @default(0)          // 表示順
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ────────────────────────────────────────
// 培養上清液注文
// ────────────────────────────────────────
model CultureFluidOrder {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id])

  // 注文内容
  planType        String                          // iv_drip_1, iv_drip_5, injection_1, injection_5
  planLabel       String                          // 表示ラベル
  totalAmount     Int                             // 金額（税込）
  paymentStatus   String    @default("PENDING")   // PENDING / COMPLETED
  paymentDate     DateTime?                       // 入金予定日
  paidAt          DateTime?                       // 入金確認日

  // ステータス（7段階）
  status          String    @default("APPLIED")
  // APPLIED → PAYMENT_CONFIRMED → PRODUCING → CLINIC_BOOKING →
  // INFORMED_AGREED → RESERVATION_CONFIRMED → COMPLETED

  // 精製・管理
  producedAt      DateTime?                       // 精製完了日
  expiresAt       DateTime?                       // 管理期限（精製日+8ヶ月）

  // クリニック情報
  clinicDate      DateTime?
  clinicName      String?
  clinicAddress   String?
  clinicPhone     String?

  // 1回の施術で使用する回数（会員がクリニック予約時に選択、最大3回分）
  requestedSessionCount Int @default(1)           // 1回の施術で消費する回数（1〜3）

  // 書類同意
  cautionAgreedAt  DateTime?                      // 留意事項同意日
  informedAgreedAt DateTime?                      // 事前説明同意日

  // 施術完了日（最新の施術回の完了日）
  completedAt     DateTime?                       // 施術完了日（管理者入力）

  // 施術回数管理（複数回施術プラン対応）
  completedSessions Int @default(0)               // 完了済み施術回数（合計回数はプランタイプから算出）
  sessionDates    String?                         // 各回の施術完了日（JSON配列: ["2026-05-28","2026-07-15",...]）

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([userId])
}
