generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ────────────────────────────────────────
// ユーザー（会員 + 管理者）
// ────────────────────────────────────────
model User {
  id            String    @id @default(cuid())
  loginId       String    @unique           // ログインID
  email         String    @unique
  passwordHash  String
  role          Role      @default(MEMBER)
  name          String
  nameKana      String?
  nameRomaji    String?                       // ローマ字氏名（カード表示用）
  phone         String?
  dateOfBirth   DateTime?
  postalCode    String?
  address       String?
  occupation    String?                       // 職業
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  lastLoginAt   DateTime?
  isActive      Boolean   @default(true)
  isIdIssued    Boolean   @default(false)   // ID発行済みか
  mustChangePassword Boolean @default(true)
  hasAgreedTerms     Boolean @default(false)  // 重要事項説明に同意済みか
  agreedTermsAt      DateTime?                // 同意日時

  // 申込情報（フォームから登録時に保存）
  applicationId    String?                    // 元の申込ID
  paymentMethod    String?                    // 支払方法
  paymentDate      DateTime?                  // 支払予定日
  salesRepName     String?                    // 担当営業者名

  // 健康状態（事前確認事項）
  currentIllness       Boolean  @default(false)
  currentIllnessDetail String?
  pastIllness          Boolean  @default(false)
  pastIllnessDetail    String?
  currentMedication    Boolean  @default(false)
  currentMedicationDetail String?
  chronicDisease       Boolean  @default(false)
  chronicDiseaseDetail String?
  infectiousDisease    Boolean  @default(false)
  infectiousDiseaseDetail String?
  pregnancy            Boolean  @default(false)
  allergy              Boolean  @default(false)
  allergyDetail        String?
  otherHealth          Boolean  @default(false)
  otherHealthDetail    String?

  membership    Membership?
  notes         AdminNote[]
  documents     Document[]
  statusHistory StatusHistory[]
}

enum Role {
  MEMBER
  ADMIN
  SUPER_ADMIN
}

// ────────────────────────────────────────
// 会員権（1ユーザー = 1会員権）
// ────────────────────────────────────────
model Membership {
  id              String          @id @default(cuid())
  userId          String          @unique
  user            User            @relation(fields: [userId], references: [id])
  memberNumber    String          @unique
  plan            MembershipPlan  @default(STANDARD)
  contractDate    DateTime
  paymentStatus   PaymentStatus   @default(PENDING)
  totalAmount     Int
  paidAmount      Int             @default(0)

  ipsStatus       IpsStatus       @default(APPLICATION)
  clinicDate      DateTime?
  ipsCompletedAt  DateTime?
  storageStartAt  DateTime?
  storageYears    Int             @default(10)

  treatments      Treatment[]

  referrerId      String?
  referrerName    String?

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

enum MembershipPlan {
  STANDARD
}

enum PaymentStatus {
  PENDING
  PARTIAL
  COMPLETED
}

enum IpsStatus {
  APPLICATION
  CONTRACT_SIGNED
  CLINIC_RESERVED
  BLOOD_COLLECTED
  IPS_CREATING
  IPS_COMPLETED
  STORAGE_ACTIVE
  STORAGE_EXPIRED
}

// ────────────────────────────────────────
// ステータス履歴（変更ログ）
// ────────────────────────────────────────
model StatusHistory {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  fromStatus  IpsStatus
  toStatus    IpsStatus
  note        String?
  changedBy   String
  changedAt   DateTime  @default(now())
}

// ────────────────────────────────────────
// 培養上清液 投与記録
// ────────────────────────────────────────
model Treatment {
  id            String          @id @default(cuid())
  membershipId  String
  membership    Membership      @relation(fields: [membershipId], references: [id])
  type          TreatmentType
  volume        Int             @default(10)
  amount        Int
  scheduledAt   DateTime?
  completedAt   DateTime?
  clinicName    String?
  note          String?
  createdAt     DateTime        @default(now())
}

enum TreatmentType {
  IV_DRIP
  LOCAL_INJECTION
}

// ────────────────────────────────────────
// 契約書類
// ────────────────────────────────────────
model Document {
  id          String         @id @default(cuid())
  userId      String
  user        User           @relation(fields: [userId], references: [id])
  type        DocumentType
  title       String
  fileUrl     String?
  signedAt    DateTime?
  status      DocumentStatus @default(PENDING)
  createdAt   DateTime       @default(now())
}

enum DocumentType {
  CONTRACT
  CONSENT_CELL_STORAGE
  INFORMED_CONSENT
  PRIVACY_POLICY
  SIMPLE_AGREEMENT
}

enum DocumentStatus {
  PENDING
  SENT
  SIGNED
  ARCHIVED
}

// ────────────────────────────────────────
// 管理者メモ（顧客カルテ用）
// ────────────────────────────────────────
model AdminNote {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  content   String
  author    String
  createdAt DateTime @default(now())
}

// ────────────────────────────────────────
// iPS ニュース記事（管理者が随時更新）
// ────────────────────────────────────────
model IpsArticle {
  id          String           @id @default(cuid())
  slug        String           @unique
  title       String
  summary     String
  content     String           @db.Text
  category    IpsArticleCategory
  imageUrl    String?
  sourceUrl   String?
  sourceName  String?
  publishedAt DateTime         @default(now())
  isPublished Boolean          @default(false)
  author      String
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

enum IpsArticleCategory {
  NEWS          // 最新ニュース
  RESEARCH      // 研究動向
  CLINICAL      // 臨床応用
  REGULATION    // 制度・規制
  MARKET        // 市場動向
}

// ────────────────────────────────────────
// 購入申込（BioVault申込書）
// ────────────────────────────────────────
model Application {
  id                String            @id @default(cuid())

  // 1. 申込者情報
  name              String                                // 氏名
  nameKana          String                                // フリガナ
  dateOfBirth       DateTime                              // 生年月日
  postalCode        String?                               // 郵便番号
  address           String                                // 住所
  phone             String                                // 電話番号
  email             String                                // メールアドレス
  occupation        String?                               // 職業

  // 2. 申込内容
  paymentMethod     String            @default("bank_transfer") // 支払方法
  paymentMethodOther String?                              // その他の場合
  paymentDate       DateTime?                             // 支払予定日
  referrerName      String?                               // 紹介者名／代理店名
  salesRepName      String?                               // 担当営業者名

  // 3. 事前確認事項（健康状態）
  currentIllness       Boolean  @default(false)           // 現在治療中の病気
  currentIllnessDetail String?
  pastIllness          Boolean  @default(false)           // 過去の病気・手術歴
  pastIllnessDetail    String?
  currentMedication    Boolean  @default(false)           // 現在使用中の薬
  currentMedicationDetail String?
  chronicDisease       Boolean  @default(false)           // 持病
  chronicDiseaseDetail String?
  infectiousDisease    Boolean  @default(false)           // 感染症
  infectiousDiseaseDetail String?
  pregnancy            Boolean  @default(false)           // 妊娠中/可能性
  allergy              Boolean  @default(false)           // アレルギー
  allergyDetail        String?
  otherHealth          Boolean  @default(false)           // その他健康上の事項
  otherHealthDetail    String?

  // 4. 確認事項チェック
  confirmNotMedical    Boolean  @default(false)           // 医療行為でないことの確認
  confirmScppRole      Boolean  @default(false)           // SCPPの役割確認
  confirmClinicRole    Boolean  @default(false)           // 提携医療機関の役割確認
  confirmLabRole       Boolean  @default(false)           // 提携先機関の役割確認
  confirmDocuments     Boolean  @default(false)           // 関連文書の確認

  // 5. 受領確認文書
  receivedContract     Boolean  @default(false)           // 会員契約書
  receivedTerms        Boolean  @default(false)           // 会員規約
  receivedImportant    Boolean  @default(false)           // 重要事項説明書
  receivedMedicalCheck Boolean  @default(false)           // 医師問診確認書
  receivedPrivacy      Boolean  @default(false)           // 個人情報同意書
  receivedCellStorage  Boolean  @default(false)           // 細胞保管同意書
  receivedIpsConsent   Boolean  @default(false)           // iPS細胞説明書

  // ステータス管理
  status            ApplicationStatus @default(PENDING)
  adminNote         String?                               // 管理者メモ
  convertedUserId   String?                               // 会員登録済みの場合のユーザーID

  applicationDate   DateTime  @default(now())             // 申込日
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

enum ApplicationStatus {
  PENDING           // 申込受付
  REVIEWING         // 審査中
  APPROVED          // 承認済
  REGISTERED        // 会員登録済
  REJECTED          // 却下
}
