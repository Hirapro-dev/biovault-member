# Database (Neon PostgreSQL)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here"

# Vercel Blob Store
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# Amazon SES（メール送信）
AWS_SES_REGION="ap-northeast-1"
AWS_SES_ACCESS_KEY="AKIA..."
AWS_SES_SECRET_KEY="..."
EMAIL_FROM="noreply@biovault.jp"

# 管理者通知先メール（申請・日程調整リクエスト等）
ADMIN_NOTIFY_EMAIL="app@biovault.jp"

# ステータス変更通知・代理店登録通知などの管理側通知メールの宛先（カンマ区切りで複数指定可）。
# 未設定の場合は app@biovault.jp に送信される。
# 例: app@biovault.jp,operator2@biovault.jp
NOTIFY_ADMIN_EMAILS="app@biovault.jp"

# テスター（master固定）アカウント。カンマ区切りでメアドを列挙すると、
# そのメアドで申込された際に loginId/password ともに "master" 固定で登録される。
TESTER_EMAILS=""

# 個別ID/PW/表示名を割り当てるテスターアカウント（伴走用アカウント等）
# 形式: email:loginId:password:displayName をカンマ区切り
# 例: ueda@gmail.com:mueda:mueda:伴走用植田,morita@gmail.com:mmorita:mmorita:伴走用守田
TESTER_ACCOUNTS=""

# 同一メールアドレスでの会員/代理店/従業員アカウント重複登録を許可するメアドの許可リスト。
# カンマ区切り、大文字小文字無視。リストに含まれるメアドのみ重複可、それ以外は従来通り重複不可。
# 例: customer@example.com,abc@example.jp
EMAIL_DUPLICATE_ALLOWLIST=""
